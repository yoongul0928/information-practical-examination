      "code": "#include <stdio.h>\nint main() {\n    int arr[3][3] = {1, 2, 3, 4, 5, 6, 7, 8, 9};\n    int* parr[2] = {arr[1], arr[2]};\n    printf(\"%d\", parr[1][1] + *(parr[1]+2) + **parr);\n    return 0;\n}",
      "code_html": "<div class=\"code-line\"><span style=\"color: #0086b3;\">#include</span> <span style=\"color: #a71d5d;\">&lt;</span>stdio.h<span style=\"color: #a71d5d;\">&gt;</span></div>\n<div class=\"code-line\"><span style=\"color: #066de2;\">int</span> main() {</div>\n<div class=\"code-line\">    <span style=\"color: #066de2;\">int</span> arr[<span style=\"color: #0099cc;\">3</span>][<span style=\"color: #0099cc;\">3</span>] <span style=\"color: #a71d5d;\">=</span> {<span style=\"color: #0099cc;\">1</span>, <span style=\"color: #0099cc;\">2</span>, <span style=\"color: #0099cc;\">3</span>, <span style=\"color: #0099cc;\">4</span>, <span style=\"color: #0099cc;\">5</span>, <span style=\"color: #0099cc;\">6</span>, <span style=\"color: #0099cc;\">7</span>, <span style=\"color: #0099cc;\">8</span>, <span style=\"color: #0099cc;\">9</span>};</div>\n<div class=\"code-line\">    <span style=\"color: #066de2;\">int</span><span style=\"color: #a71d5d;\">*</span> parr[<span style=\"color: #0099cc;\">2</span>] <span style=\"color: #a71d5d;\">=</span> {arr[<span style=\"color: #0099cc;\">1</span>], arr[<span style=\"color: #0099cc;\">2</span>]};</div>\n<div class=\"code-line\">    <span style=\"color: #066de2;\">printf</span>(<span style=\"color: #63a35c;\">\"%d\"</span>, parr[<span style=\"color: #0099cc;\">1</span>][<span style=\"color: #0099cc;\">1</span>] <span style=\"color: #a71d5d;\">+</span> <span style=\"color: #a71d5d;\">*</span>(parr[<span style=\"color: #0099cc;\">1</span>]<span style=\"color: #a71d5d;\">+</span><span style=\"color: #0099cc;\">2</span>) <span style=\"color: #a71d5d;\">+</span> <span style=\"color: #a71d5d;\">*</span><span style=\"color: #a71d5d;\">*</span>parr);</div>\n<div class=\"code-line\">    <span style=\"color: #a71d5d;\">return</span> <span style=\"color: #0099cc;\">0</span>;</div>\n<div class=\"code-line\">}</div>",
