      "code": "#include <stdio.h>\n#include <string.h>\nvoid sumFn(char* d, const char* s) {\n    while (*s) {\n        *d = *s;\n        d++;\n        s++;\n    }\n    *d = '\\0';\n}\nint main() {\n   const char* str1 = \"first\";\n    char str2[50] = \"teststring\";\n    int result=0;\n    sumFn(str2, str1);\n    for (int i = 0; str2[i] != '\\0'; i++) {\n        result += i;\n    }\n    printf(\"%d\", result);\n    return 0;\n}",
      "code_html": "<div class=\"code-line\"><span style=\"color: #0086b3;\">#include</span> <span style=\"color: #a71d5d;\">&lt;</span>stdio.h<span style=\"color: #a71d5d;\">&gt;</span></div>\n<div class=\"code-line\"><span style=\"color: #0086b3;\">#include</span> <span style=\"color: #a71d5d;\">&lt;</span><span style=\"color: #066de2;\">string</span>.h<span style=\"color: #a71d5d;\">&gt;</span></div>\n<div class=\"code-line\"><span style=\"color: #a71d5d;\">void</span> sumFn(<span style=\"color: #066de2;\">char</span><span style=\"color: #a71d5d;\">*</span> d, const <span style=\"color: #066de2;\">char</span><span style=\"color: #a71d5d;\">*</span> s) {</div>\n<div class=\"code-line\">    <span style=\"color: #a71d5d;\">while</span> (<span style=\"color: #a71d5d;\">*</span>s) {</div>\n<div class=\"code-line\">        <span style=\"color: #a71d5d;\">*</span>d <span style=\"color: #a71d5d;\">=</span> <span style=\"color: #a71d5d;\">*</span>s;</div>\n<div class=\"code-line\">        d<span style=\"color: #a71d5d;\">+</span><span style=\"color: #a71d5d;\">+</span>;</div>\n<div class=\"code-line\">        s<span style=\"color: #a71d5d;\">+</span><span style=\"color: #a71d5d;\">+</span>;</div>\n<div class=\"code-line\">    }</div>\n<div class=\"code-line\">    <span style=\"color: #a71d5d;\">*</span>d <span style=\"color: #a71d5d;\">=</span> <span style=\"color: #63a35c;\">'\\0'</span>; </div>\n<div class=\"code-line\">}</div>\n<div class=\"code-line\"><span style=\"color: #066de2;\">int</span> main() {</div>\n<div class=\"code-line\">   <span style=\"background-color: #fafafa; color: #010101; text-align: left;\">const </span><span style=\"color: #066de2;\">char</span><span style=\"color: #a71d5d;\">*</span> str1 <span style=\"color: #a71d5d;\">=</span> <span style=\"color: #63a35c;\">\"first\"</span>;</div>\n<div class=\"code-line\">    <span style=\"color: #066de2;\">char</span> str2[<span style=\"color: #0099cc;\">50</span>] <span style=\"color: #a71d5d;\">=</span> <span style=\"color: #63a35c;\">\"teststring\"</span>;  </div>\n<div class=\"code-line\">    <span style=\"color: #066de2;\">int</span> result<span style=\"color: #a71d5d;\">=</span><span style=\"color: #0099cc;\">0</span>;</div>\n<div class=\"code-line\">    sumFn(str2, str1);</div>\n<div class=\"code-line\">    <span style=\"color: #a71d5d;\">for</span> (<span style=\"color: #066de2;\">int</span> i <span style=\"color: #a71d5d;\">=</span> <span style=\"color: #0099cc;\">0</span>; str2[i] <span style=\"color: #a71d5d;\">!</span><span style=\"color: #a71d5d;\">=</span> <span style=\"color: #63a35c;\">'\\0'</span>; i<span style=\"color: #a71d5d;\">+</span><span style=\"color: #a71d5d;\">+</span>) {</div>\n<div class=\"code-line\">        result <span style=\"color: #a71d5d;\">+</span><span style=\"color: #a71d5d;\">=</span> i;</div>\n<div class=\"code-line\">    }</div>\n<div class=\"code-line\">    <span style=\"color: #066de2;\">printf</span>(<span style=\"color: #63a35c;\">\"%d\"</span>, result);</div>\n<div class=\"code-line\">    <span style=\"color: #a71d5d;\">return</span> <span style=\"color: #0099cc;\">0</span>;</div>\n<div class=\"code-line\">}</div>",
