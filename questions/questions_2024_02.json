r: #066de2;\">String</span> result <span style=\"color: #a71d5d;\">=</span> calculFn(str, index<span style=\"color: #a71d5d;\">-</span><span style=\"color: #0099cc;\">1</span>, seen);</div>\n<div class=\"code-line\">        <span style=\"color: #a71d5d;\">if</span>(<span style=\"color: #a71d5d;\">!</span>seen[c]) {</div>\n<div class=\"code-line\">            seen[c] <span style=\"color: #a71d5d;\">=</span> <span style=\"color: #0099cc;\">true</span>;</div>\n<div class=\"code-line\">            <span style=\"color: #a71d5d;\">return</span> c <span style=\"color: #a71d5d;\">+</span> result;</div>\n<div class=\"code-line\">        }</div>\n<div class=\"code-line\">        <span style=\"color: #a71d5d;\">return</span> result;</div>\n<div class=\"code-line\">    }</div>\n<div class=\"code-line\">}</div>",
